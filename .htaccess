RewriteEngine On

# ── Un solo redirect: cualquier variante HTTP/non-www → https://www.valirica.com ──
# Cubre los 4 casos en un único 301 (sin doble redirect):
#   http://valirica.com      → https://www.valirica.com
#   http://www.valirica.com  → https://www.valirica.com
#   https://valirica.com     → https://www.valirica.com
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteRule ^(.*)$ https://www.valirica.com/$1 [L,R=301]

# ── Cache de activos estaticos (1 año) ────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css               "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/svg+xml          "access plus 1 year"
  ExpiresByType image/jpeg             "access plus 1 year"
  ExpiresByType image/png              "access plus 1 year"
  ExpiresByType image/webp             "access plus 1 year"
  ExpiresByType font/woff2             "access plus 1 year"
</IfModule>

# ── Compresion Gzip ────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript
</IfModule>
