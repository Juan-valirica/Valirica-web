RewriteEngine On

# ── Un solo redirect: cualquier variante HTTP/non-www → https://www.valirica.com ──
# Cubre los 4 casos en un único 301 (sin doble redirect):
#   http://valirica.com      → https://www.valirica.com
#   http://www.valirica.com  → https://www.valirica.com
#   https://valirica.com     → https://www.valirica.com
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteRule ^(.*)$ https://www.valirica.com/$1 [L,R=301]

# ── HTTP/2+ ─────────────────────────────────────────────
<IfModule mod_http2.c>
  Protocols h2 h2c http/1.1
</IfModule>

# ── Cache de activos estaticos (1 año) ────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css               "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/svg+xml          "access plus 1 year"
  ExpiresByType image/jpeg             "access plus 1 year"
  ExpiresByType image/png              "access plus 1 year"
  ExpiresByType image/webp             "access plus 1 year"
  ExpiresByType font/woff2             "access plus 1 year"
  ExpiresByType text/html              "access plus 1 hour"
</IfModule>

# ── Compresion Gzip ────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml font/woff2
</IfModule>

# ── Vary: Accept-Encoding (evita caches incorrectas) ──────────
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|html|svg)$">
    Header append Vary Accept-Encoding
  </FilesMatch>
</IfModule>

# ── Cabeceras de seguridad (mejoran Core Web Vitals y reputación) ──
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options       "nosniff"
  Header always set X-Frame-Options              "SAMEORIGIN"
  Header always set Referrer-Policy              "strict-origin-when-cross-origin"
  Header always set Permissions-Policy           "camera=(), microphone=(), geolocation=(self)"
  Header always set X-XSS-Protection             "1; mode=block"
</IfModule>

# ── Content-Type con charset para HTML ───────────────────────
<IfModule mod_mime.c>
  AddCharset UTF-8 .html .css .js .json .xml .txt
</IfModule>
